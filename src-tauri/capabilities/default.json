{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:9091/*" },
        { "url": "http://localhost:9091/*" }
      ]
    }
  ]
}
